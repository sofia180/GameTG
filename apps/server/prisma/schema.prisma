generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TransactionType {
  deposit
  withdraw
  bet
  win
}

enum TransactionStatus {
  pending
  completed
  failed
  locked
  refunded
}

enum GameStatus {
  waiting
  active
  finished
  cancelled
}

enum GameType {
  chess
  checkers
  tictactoe
  battleship
  durak
  mafia
}

enum TournamentStatus {
  draft
  active
  completed
  cancelled
}

model Tournament {
  id         String            @id @default(uuid())
  title      String
  game       String
  entryFee   Decimal           @default(0)
  prizePool  Decimal           @default(0)
  status     TournamentStatus  @default(draft)
  bracket    Json?
  startsAt   DateTime?
  createdAt  DateTime          @default(now())
  createdById String?

  createdBy  User?             @relation(fields: [createdById], references: [id])
  participants TournamentParticipant[]
  matches    TournamentMatch[]
}

model TournamentParticipant {
  id            String   @id @default(uuid())
  tournamentId  String
  userId        String
  seed          Int?
  paid          Boolean  @default(false)
  eliminated    Boolean  @default(false)
  createdAt     DateTime @default(now())

  tournament Tournament @relation(fields: [tournamentId], references: [id])
  user       User       @relation(fields: [userId], references: [id])

  @@unique([tournamentId, userId])
  @@index([tournamentId, paid])
}

model TournamentMatch {
  id            String   @id @default(uuid())
  tournamentId  String
  round         Int
  player1Id     String?
  player2Id     String?
  winnerId      String?
  report        Json?
  externalMatchId String?
  createdAt     DateTime @default(now())

  tournament Tournament @relation(fields: [tournamentId], references: [id])
  player1    User?      @relation("TM_P1", fields: [player1Id], references: [id])
  player2    User?      @relation("TM_P2", fields: [player2Id], references: [id])
  winner     User?      @relation("TM_Winner", fields: [winnerId], references: [id])

  @@index([tournamentId, round])
}

model User {
  id           String   @id @default(uuid())
  telegramId   String   @unique
  username     String?
  referralCode String   @unique
  referredById String?
  isBanned     Boolean  @default(false)
  createdAt    DateTime @default(now())

  referredBy   User?    @relation("UserReferrals", fields: [referredById], references: [id])
  referrals    User[]   @relation("UserReferrals")

  wallet       Wallet?
  transactions Transaction[]
  roomsAsP1    GameRoom[] @relation("Player1")
  roomsAsP2    GameRoom[] @relation("Player2")
  wins         GameRoom[] @relation("Winner")
  moves        GameMove[]
  referralRewards ReferralReward[] @relation("ReferrerRewards")
  referredRewards ReferralReward[] @relation("UserRewards")
}

model Wallet {
  id        String   @id @default(uuid())
  userId    String   @unique
  balance   Decimal  @default(0)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Transaction {
  id        String             @id @default(uuid())
  userId    String
  type      TransactionType
  amount    Decimal
  status    TransactionStatus @default(pending)
  metadata  Json?
  referenceId String? @unique
  createdAt DateTime          @default(now())

  user User @relation(fields: [userId], references: [id])
}

model GameRoom {
  id        String     @id @default(uuid())
  gameType  GameType
  stake     Decimal
  status    GameStatus @default(waiting)
  player1Id String
  player2Id String?
  winnerId  String?
  createdAt DateTime @default(now())
  roomCode  String   @unique
  isPrivate Boolean  @default(false)

  player1 User  @relation("Player1", fields: [player1Id], references: [id])
  player2 User? @relation("Player2", fields: [player2Id], references: [id])
  winner  User? @relation("Winner", fields: [winnerId], references: [id])
  moves   GameMove[]
}

model GameMove {
  id        String   @id @default(uuid())
  gameId    String
  playerId  String
  move      Json
  createdAt DateTime @default(now())

  game   GameRoom @relation(fields: [gameId], references: [id])
  player User     @relation(fields: [playerId], references: [id])
}

model ReferralReward {
  id         String   @id @default(uuid())
  referrerId String
  userId     String
  amount     Decimal
  createdAt  DateTime @default(now())

  referrer User @relation("ReferrerRewards", fields: [referrerId], references: [id])
  user     User @relation("UserRewards", fields: [userId], references: [id])
}
